# ===== ActivatePro IMEI backend config =====
# Pick a provider: mock | imeilookup | sickw | dhru
IMEI_PROVIDER=mock

# Server
PORT=8787
# Secret for signing JWT session tokens — set a long random string in production
JWT_SECRET=

# ---- Payments: Midtrans (Indonesia) ----
# SERVER key (secret, backend only) from Midtrans dashboard. Set MIDTRANS_IS_PRODUCTION=1 for live.
# The CLIENT key goes in the frontend: CONFIG.midtransClientKey in app.js.
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=0
# Lock this down to your frontend origin in production
ALLOWED_ORIGIN=*
# Set to 1 to include the provider's raw payload in responses (debugging)
RETURN_RAW=0

# ---- OTP email via Brevo (https://app.brevo.com) ----
# Create an API key: Brevo → SMTP & API → API Keys
BREVO_API_KEY=
# Must be a VERIFIED sender in your Brevo account (Senders, Domains & Dedicated IPs)
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=ActivatePro
# How long a code stays valid (seconds)
OTP_TTL_SECONDS=300
# TESTING ONLY: return the OTP in the API response so you can test without email. Keep 0 in production.
OTP_DEV_RETURN=0

# ---- imeilookup.com (advertises a free tier — rate-limited) ----
IMEILOOKUP_API_KEY=
IMEILOOKUP_API_URL=https://api.imeilookup.com/check
IMEILOOKUP_SERVICE=

# ---- Sickw (https://sickw.com/api) ----
SICKW_API_KEY=
# Service ID for the FMI / GSX / blacklist service on your plan
SICKW_SERVICE_ID=

# ---- DHRU Fusion (ifreeicloud and similar) ----
DHRU_API_URL=
DHRU_USERNAME=
DHRU_API_KEY=
DHRU_SERVICE_ID=
